# =============================================================================
# WannaBuild environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in any values you
# want repo scripts and CI helpers to honor on your machine.
#
# Security posture
# ----------------
# WannaBuild is a docs/framework repo: it has NO REQUIRED runtime secrets.
# Every variable below is OPTIONAL. The repo scripts run fine with all of them
# unset. Set them only when you need the corresponding capability (telemetry,
# tracing, error tracking, GitHub admin operations, etc.).
#
# Never commit secrets. The pre-commit hook and the `detect-secrets` scanner
# will flag accidental leaks. See `docs/secrets-management.md` and
# `docs/runbooks/secret-leak-incident.md` if a secret leaks.
# =============================================================================

# ---- Logging ----
# Verbosity: debug | info | warn | error  (default: info)
WB_LOG_LEVEL=info
# Format: text | json  (default: text)
WB_LOG_FORMAT=text

# ---- Testing ----
# Number of parallel test jobs (default: 4)
BATS_JOBS=4
# Coverage threshold percentage (default: 60)
COVERAGE_THRESHOLD=60

# ---- DevContainer ----
# Set to 1 inside the dev container (used by scripts to detect environment)
WB_DEV_CONTAINER=

# ---- Telemetry / metrics (CI runtime metrics for the framework itself) ----
# If set, scripts/ci-metrics-collect.sh emits run-duration metrics to this endpoint.
# Optional. Leave blank to disable.
WB_METRICS_ENDPOINT=
WB_METRICS_TOKEN=

# ---- Tracing ----
# OTLP endpoint for OpenTelemetry traces emitted by long-running scripts
# (e.g., orchestrator runs in target projects). Optional.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=wannabuild

# ---- Error tracking (target-project guidance; framework forwards if set) ----
# Sentry DSN for capturing unhandled errors in long-running scripts. Optional.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# ---- GitHub release / governance scripts ----
# Required ONLY when running scripts/apply-rulesets.sh or release maintenance commands.
# Use a fine-grained PAT with admin:repo for the wannabuild repo. Never commit.
GH_TOKEN=

# ---- Renovate / dependency automation (CI-side; not used locally) ----
RENOVATE_TOKEN=
