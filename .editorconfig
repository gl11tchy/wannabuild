# EditorConfig: https://editorconfig.org
# Top-level config for the WannaBuild repo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown: keep trailing whitespace tolerant (line breaks via `  `).
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 2

[*.{yaml,yml,json,jsonc}]
indent_size = 2

[Makefile]
indent_style = tab
