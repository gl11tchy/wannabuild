{
  "schema_version": 1,
  "host_invocations": {
    "claude_code": {
      "start": "/wannabuild",
      "intro": "/using-wannabuild"
    },
    "codex": {
      "start": "$wannabuild",
      "intro": "$using-wannabuild"
    }
  },
  "required_scenarios": [
    "no-task-invocation",
    "exploratory-discovery-invocation",
    "wb-discover-entrypoint-full-loop",
    "vague-acknowledgment-no-phase-skip",
    "runtime-plan-gate",
    "implementation-workspace-selection",
    "resume",
    "research-gate",
    "implementation-selection",
    "review-failure",
    "qa-failure",
    "summary-completion"
  ],
  "scenarios": [
    {
      "id": "no-task-invocation",
      "description": "A bare /wannabuild or $wannabuild invocation asks for the concrete task and does not inspect or infer from git state.",
      "fixture": "no-task-invocation.json",
      "prompt_has_concrete_task": false,
      "next_prompt": "Tell me what you want to build or change.",
      "must_not": [
        "inspect_repo",
        "infer_git_diff",
        "plan",
        "implement"
      ]
    },
    {
      "id": "exploratory-discovery-invocation",
      "description": "A rough ideation prompt starts Discover automatically instead of falling back to the no-task response.",
      "fixture": "exploratory-discovery-invocation.json"
    },
    {
      "id": "wb-discover-entrypoint-full-loop",
      "description": "A concrete wb-discover invocation starts at Discover, produces requirements, and continues through Plan, Build, Review, QA, Ship, and Summary unless explicitly limited.",
      "fixture": "wb-discover-entrypoint-full-loop.json"
    },
    {
      "id": "vague-acknowledgment-no-phase-skip",
      "description": "A vague acknowledgment during an active workflow continues the current phase and is not treated as permission to skip planning or stop the loop.",
      "fixture": "vague-acknowledgment-no-phase-skip.json"
    },
    {
      "id": "runtime-plan-gate",
      "description": "Runtime context injects active workflow state and forbids implementation until the planning gate passes.",
      "fixture": "runtime-plan-gate.json"
    },
    {
      "id": "implementation-workspace-selection",
      "description": "Under explicitly selected autonomous mode, implementation can use an isolated worktree when selected, while earlier stages stay in the current checkout.",
      "fixture": "workspace-bootstrap-state.json",
      "workspace_fixture": "workspace-bootstrap-workspace.json",
      "branch_prefixes": [
        "codex/",
        "wannabuild/"
      ],
      "expect": {
        "public_stage": "discover",
        "workflow_status": "in_progress",
        "control_mode": "autonomous"
      },
      "required_public_history": [
        "discover"
      ]
    },
    {
      "id": "resume",
      "description": "Existing state resumes from the current phase and checkpoint context rather than restarting the workflow.",
      "fixture": "resume-state.json",
      "expect": {
        "current_phase": "implement",
        "phase_status": "in_progress",
        "public_stage": "implement",
        "workflow_status": "in_progress"
      },
      "required_public_history": [
        "discover",
        "plan",
        "implement"
      ]
    },
    {
      "id": "research-gate",
      "description": "When research is selected, the public stage records research and stores the research summary before planning.",
      "fixture": "research-gate-taken-state.json",
      "expect": {
        "public_stage": "plan",
        "workflow_status": "in_progress"
      },
      "required_public_history": [
        "discover",
        "research"
      ]
    },
    {
      "id": "implementation-selection",
      "description": "In explicitly selected autonomous mode, after planning, implementation starts with the selected adaptive execution shape without pausing for a per-boundary gate. (In the default guided mode the Plan -> Implement boundary requires explicit user approval.)",
      "fixture": "implement-gate-denied-state.json",
      "expect": {
        "current_phase": "implement",
        "phase_status": "in_progress",
        "public_stage": "implement",
        "workflow_status": "in_progress",
        "control_mode": "autonomous"
      },
      "latest_public_stage_expect": {
        "stage": "implement",
        "status": "in_progress",
        "execution_shape": "single-owner"
      }
    },
    {
      "id": "review-failure",
      "description": "A failing reviewer verdict blocks summary completion until the review loop is remediated.",
      "fixture": "review-failure-loop.json",
      "expect": {
        "status": "blocked"
      },
      "latest_iteration_expect": {
        "fail_count": 1,
        "verdicts.wb-architecture-reviewer.status": "FAIL"
      }
    },
    {
      "id": "qa-failure",
      "description": "A failing integration hard gate keeps the workflow in remediation and blocks completion.",
      "fixture": "qa-failure-remediation-loop.json",
      "expect": {
        "status": "in_progress"
      },
      "latest_iteration_expect": {
        "fail_count": 1,
        "verdicts.wb-integration-tester.status": "FAIL",
        "verdicts.wb-integration-tester.hard_gate": true
      }
    },
    {
      "id": "summary-completion",
      "description": "Summary is only complete after review and QA have both passed and evidence exists.",
      "fixture": "summary-complete-state.json",
      "expect": {
        "public_stage": "summary",
        "workflow_status": "complete",
        "phase_status": "complete"
      },
      "required_public_history": [
        "review",
        "qa",
        "summary"
      ]
    }
  ]
}
