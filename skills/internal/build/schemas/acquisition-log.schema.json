{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WannaBuild acquisition log",
  "description": "Records resource-acquisition attempts (doctrine Mandate 2). Required before any blocked/failed status is accepted; assert-acquisition-attempted rejects a blocker with no logged attempt.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "need",
      "tools_tried",
      "result"
    ],
    "properties": {
      "need": {
        "type": "string",
        "minLength": 1
      },
      "tools_tried": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "result": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
