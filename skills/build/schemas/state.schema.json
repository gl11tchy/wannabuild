{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WannaBuild state.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "project",
    "current_phase",
    "phase_status",
    "control_mode",
    "artifacts",
    "started_at",
    "updated_at",
    "phase_history"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "standard"
      ]
    },
    "current_phase": {
      "type": "string",
      "minLength": 1
    },
    "control_mode": {
      "type": "string",
      "enum": [
        "guided",
        "autonomous"
      ]
    },
    "phase_status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "complete"
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "started_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "phase_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phase",
          "status",
          "timestamp"
        ],
        "properties": {
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "complete"
            ]
          },
          "timestamp": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
          }
        },
        "additionalProperties": true
      }
    },
    "advisor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "max_uses_per_phase": {
          "type": "integer",
          "minimum": 0
        },
        "uses_by_phase": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "escalations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "phase",
              "trigger",
              "report",
              "decision_impact",
              "recorded_in_decisions"
            ],
            "properties": {
              "phase": {
                "type": "string",
                "minLength": 1
              },
              "trigger": {
                "type": "string",
                "minLength": 1
              },
              "report": {
                "type": "string",
                "minLength": 1
              },
              "decision_impact": {
                "type": "string",
                "enum": [
                  "none",
                  "scope",
                  "architecture",
                  "implementation",
                  "validation"
                ]
              },
              "recorded_in_decisions": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
