{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WannaBuild state.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "project",
    "mode",
    "current_phase",
    "phase_status",
    "artifacts",
    "started_at",
    "updated_at",
    "phase_history"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "full",
        "light"
      ]
    },
    "current_phase": {
      "type": "string",
      "minLength": 1
    },
    "phase_status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "complete"
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "started_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "phase_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phase",
          "status",
          "timestamp"
        ],
        "properties": {
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "complete"
            ]
          },
          "timestamp": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
